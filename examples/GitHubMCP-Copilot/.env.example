# GitHub MCP Server Authentication
# Use one of the following auth methods — never both at once

# Option 1: Personal Access Token (PAT)
# Generate at: https://github.com/settings/tokens
# For GitHub.com
GITHUB_TOKEN=your_github_pat_here

# For GitHub Enterprise Cloud with data residency
# GITHUB_TOKEN=your_ghe_pat_here

# Option 2: OAuth
# No env variable needed — handled automatically by the remote server

# Per-project PAT examples (for teams managing multiple clients or repos)
# GITHUB_CLIENT_A_TOKEN=client_a_pat_here
# GITHUB_CLIENT_B_TOKEN=client_b_pat_here

# Internal agent communication (for lib/ layer)
INTERNAL_AGENT_TOKEN=generate_a_random_secret_here

# Guardrail alert destination (optional — defaults to console)
# GUARDRAIL_WEBHOOK_URL=https://hooks.slack.com/your_webhook_url

# GitHub Enterprise Cloud subdomain (if applicable)
# GHE_SUBDOMAIN=your_org_subdomain
