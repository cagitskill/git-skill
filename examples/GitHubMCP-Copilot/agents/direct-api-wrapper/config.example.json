{
  "pattern": "repository-access",
  "mcp_server": {
    "id": "github",
    "url": "https://api.githubcopilot.com/mcp/",
    "auth": {
      "method": "oauth",
      "note": "For PAT auth, replace with: { \"method\": \"pat\", \"token_env\": \"GITHUB_TOKEN\" }"
    }
  },
  "tools_enabled": [
    "get_file_contents",
    "search_code",
    "list_commits",
    "get_commit",
    "list_branches"
  ],
  "guardrail_reporting": true,
  "active": true
}
